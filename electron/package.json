{
  "name": "secure-exam-browser",
  "productName": "Prodigy Browser",
  "version": "1.0.1",
  "description": "A secure, locked-down browser for digital exams",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "start:admin": "electron . --admin",
    "build": "electron-builder",
    "build:admin": "electron-builder --config electron-builder-admin.yml",
    "dist:win": "electron-builder --win",
    "dist:win:admin": "electron-builder --win --config electron-builder-admin.yml",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [
    "exam",
    "secure",
    "browser",
    "kiosk"
  ],
  "author": "SecureExam",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "open-dyslexic": "^1.0.3"
  }
}
