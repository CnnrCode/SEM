<?xml version="1.0" encoding="utf-8"?>
<!-- Toast notification card matching PC browser's slide-in toast -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/toast_bg"
    android:elevation="12dp"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Header row: title + close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/toastTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🛡️ AI Blocking Shield"
            android:textColor="#ef4444"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <ImageButton
            android:id="@+id/toastClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Dismiss"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#94a3b8" />

    </LinearLayout>

    <!-- Body text -->
    <TextView
        android:id="@+id/toastBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="This website is blocked."
        android:textColor="#94a3b8"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.4" />

</LinearLayout>
